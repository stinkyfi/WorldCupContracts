# Copy to `.env` and fill in. Never commit `.env`.

# Deployer wallet (0x-prefixed private key; required for live networks)
DEPLOYER_PRIVATE_KEY=

# --- Base ---
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# --- Avalanche ---
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# --- Sonic ---
SONIC_RPC_URL=https://rpc.soniclabs.com
SONIC_TESTNET_RPC_URL=https://rpc.blaze.soniclabs.com

# Optional: default USDC on Sonic when not using TOKEN_ADDRESS
# SONIC_DEFAULT_USDC=
# SONIC_TESTNET_DEFAULT_USDC=

# Optional: WETH / wrapped native on Sonic or Fuji when not using TOKEN_ADDRESS
# SONIC_DEFAULT_WETH=
# SONIC_TESTNET_DEFAULT_WETH=
# FUJI_WETH_TOKEN=

# Deploy script overrides (any network)
# TOKEN_ADDRESS=
# ENTRY_FEE_UNITS=20
# ENTRY_FEE_DECIMALS=6
